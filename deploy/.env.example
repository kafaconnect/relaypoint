# RelayPoint deploy credentials. Copy to `.env` and change the values for anything beyond
# a local dev box. `.env` is gitignored; NEVER commit real secrets. These dev defaults match
# the compose `:-` fallbacks, so a bare `docker compose up` works without copying this file.

# NATS `router` user — the sole writer of interaction.<id>.log. Must match what the router
# service authenticates with (compose wires both from this one variable).
ROUTER_PASSWORD=router-dev

# NATS `projector` user — the fan-out worker (its OWN least-privilege identity, never shared
# with `router`): tails `.log` read-only, writes AGENT_FEED + DLQ, holds its leader lease in KV.
PROJECTOR_PASSWORD=projector-dev

# NATS `client` user — DEV-ONLY shared browser/app fallback (read-only on .log, write-only on
# .cmd/.signal). Exempt from the auth-callout; remove once all clients present a token.
CLIENT_PASSWORD=client-dev

# --- Auth-callout (agent-feed-fanout V2-01) ---------------------------------------------------
# The responder verifies each connection's token and MINTS its per-connection, identity-pinned
# ACLs (replacing the shared `client` user). These are SECRETS — never commit real values.
#
# NATS `authsvc` user — the responder's static credential (an auth_users member, callout-exempt).
AUTH_PASSWORD=auth-dev
# The auth account signing key. AUTH_CALLOUT_ISSUER is the PUBLIC nkey (`A…`) used by the NATS
# config; AUTH_CALLOUT_ISSUER_SEED is the matching SEED (`SA…`) used ONLY by the responder process.
# Mint a pair with `nk -gen account -pubout` (or nats-io/nkeys CreateAccount). NEVER commit the seed.
AUTH_CALLOUT_ISSUER=AEXAMPLE_REPLACE_WITH_A_REAL_ACCOUNT_PUBLIC_NKEY
AUTH_CALLOUT_ISSUER_SEED=SAEXAMPLE_REPLACE_WITH_THE_MATCHING_ACCOUNT_SEED
# Shared secret the responder validates the dev bearer token with (a real deployment backs the
# Verifier with the issuer's JWKS/OIDC instead).
AUTH_TOKEN_SECRET=auth-token-dev-secret

# coturn long-term credential for WebRTC TURN relay (dev only).
COTURN_USER=relaypoint
COTURN_PASSWORD=relaypoint-dev
