{
  "name": "@relaypoint/client",
  "version": "0.1.0-chat",
  "description": "RelayPoint browser SDK — chat subset over the signaling-core router-authoritative protocol",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/fake-transport.d.ts",
      "import": "./dist/testing/fake-transport.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "nats.ws": "^1.30.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kafaconnect/relaypoint.git",
    "directory": "clients/typescript"
  }
}
